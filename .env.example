# Firebase web app config. Copy this file to ".env" and fill in the values
# from Firebase Console -> Project settings -> Your apps -> SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- OpenAI (server-side only) -------------------------------------------------
# Used exclusively by the Vercel serverless function in /api/ai.js. Do NOT prefix
# with VITE_ — that would inline the secret into the browser bundle. Set the real
# value locally in .env (git-ignored) and in Vercel → Settings → Environment
# Variables for Production + Preview.
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini (fast + cheap).
OPENAI_MODEL=gpt-4o-mini
